#  Versatile Pub â€” Environment Variables
#  Copy this file to .env and fill in values
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/versatile_pub
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/versatile_pub

# JWT
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=30d

# Admin credentials (used to seed the DB on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChefP2026!

# Paystack
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PUBLIC_KEY


# OneSignal Web Push
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
ONESIGNAL_REST_KEY=YOUR_ONESIGNAL_REST_KEY
ONESIGNAL_SAFARI_WEB_ID=web.onesignal.auto.REPLACE_WITH_YOUR_SAFARI_WEB_ID

# WhatsApp (restaurant number for notifications)
RESTAURANT_WHATSAPP=2349052155013

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
